<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>

<BorderPane fx:id="rootPane" xmlns="http://javafx.com/fxml/1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pharmacy.controller.MainController"
            styleClass="root-pane">
    
    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" spacing="15" prefWidth="240">
            <padding>
                <Insets top="30" right="20" bottom="20" left="20"/>
            </padding>
            
            <!-- Brand Logo Header -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox>
                    <Label text="Pharmacy Management System" styleClass="brand-title"/>
                    <Label text="Pharmacy Suite" styleClass="brand-subtitle"/>
                </VBox>
            </HBox>
            
            <Separator styleClass="sidebar-separator"/>
            
            <!-- Navigation Links -->
            <VBox spacing="8" VBox.vgrow="ALWAYS">
                <Button fx:id="btnDashboard" text="✥  Dashboard" onAction="#handleNavDashboard" styleClass="nav-button, nav-button-active" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                <Button fx:id="btnInventory" text="📦  Inventory Manager" onAction="#handleNavInventory" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                <Button fx:id="btnSales" text="📊  Point of Sale" onAction="#handleNavSales" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                <Button fx:id="btnTransactions" text="📜  Transaction History" onAction="#handleNavTransactions" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
            </VBox>
            <!-- Footer Navigation -->
            <VBox spacing="8">
                <Button fx:id="btnLogout" text="🚪  Log Out" onAction="#handleLogout" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
                <Button fx:id="btnToggleTheme" text="🌗 Toggle Dark Mode" onAction="#handleToggleTheme" styleClass="nav-button" maxWidth="Infinity" alignment="BASELINE_LEFT"/>
            </VBox>
            
            <!-- Sidebar Footer User Profile -->
            <VBox styleClass="profile-box" spacing="5">
                <padding>
                    <Insets top="12" right="15" bottom="12" left="15"/>
                </padding>
                <Label fx:id="lblProfileName" text="User" styleClass="profile-name"/>
                <Label fx:id="lblProfileRole" text="Role" styleClass="profile-role"/>
            </VBox>
        </VBox>
    </left>

    <!-- CENTER CONTENT — Pure Analytics Dashboard -->
    <center>
        <VBox fx:id="centerContent" spacing="20" styleClass="main-content">
            <padding>
                <Insets top="30" right="25" bottom="25" left="25"/>
            </padding>
            
            <!-- Dashboard Title Header -->
            <HBox alignment="CENTER_LEFT">
                <VBox>
                    <Label text="Analytics Dashboard" styleClass="page-title"/>
                    <Label text="Real-time pharmacy performance metrics and revenue trends" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="System Online" styleClass="status-badge-online"/>
            </HBox>

            <!-- STATISTIC CARDS PANEL -->
            <HBox spacing="15" styleClass="stat-cards-container">
                <!-- Card 1: Total Medicines -->
                <VBox styleClass="stat-card, stat-card-teal" HBox.hgrow="ALWAYS" spacing="5">
                    <padding>
                        <Insets top="15" right="20" bottom="15" left="20"/>
                    </padding>
                    <Label text="Total Formulations" styleClass="stat-label"/>
                    <Label fx:id="lblTotalMedicines" text="0" styleClass="stat-value"/>
                </VBox>
                
                <!-- Card 2: Low Stock -->
                <VBox styleClass="stat-card, stat-card-amber" HBox.hgrow="ALWAYS" spacing="5">
                    <padding>
                        <Insets top="15" right="20" bottom="15" left="20"/>
                    </padding>
                    <Label text="Low Stock Alerts" styleClass="stat-label"/>
                    <Label fx:id="lblLowStock" text="0" styleClass="stat-value"/>
                </VBox>

                <!-- Card 3: Out of Stock -->
                <VBox styleClass="stat-card, stat-card-rose" HBox.hgrow="ALWAYS" spacing="5">
                    <padding>
                        <Insets top="15" right="20" bottom="15" left="20"/>
                    </padding>
                    <Label text="Out of Stock" styleClass="stat-label"/>
                    <Label fx:id="lblOutofStock" text="0" styleClass="stat-value"/>
                </VBox>

                <!-- Card 4: Inventory Valuation -->
                <VBox styleClass="stat-card, stat-card-blue" HBox.hgrow="ALWAYS" spacing="5">
                    <padding>
                        <Insets top="15" right="20" bottom="15" left="20"/>
                    </padding>
                    <Label text="Total Net Valuation" styleClass="stat-label"/>
                    <Label fx:id="lblTotalValuation" text="0.00" styleClass="stat-value"/>
                </VBox>
            </HBox>

            <!-- REVENUE LINE CHART — Large & Prominent -->
            <VBox styleClass="table-container" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <LineChart fx:id="revenueChart" title="Revenue — Last 7 Days" VBox.vgrow="ALWAYS" createSymbols="true" animated="true" minHeight="300">
                    <xAxis>
                        <CategoryAxis label="Date"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Revenue (₵)"/>
                    </yAxis>
                </LineChart>
            </VBox>

            <!-- LOW STOCK ALERTS PANEL -->
            <VBox fx:id="dashboardAlertsBox" styleClass="stat-card, stat-card-amber" spacing="8">
                <padding>
                    <Insets top="15" right="20" bottom="15" left="20"/>
                </padding>
                <Label text="⚠ Low Stock &amp; Out of Stock Alerts" styleClass="stat-label" style="-fx-text-fill: #fbbf24; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            </VBox>
        </VBox>
    </center>

</BorderPane>
